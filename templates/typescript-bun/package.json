{
  "name": "bun-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "module": "src/index.ts",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
